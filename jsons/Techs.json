            {
                "name": "Beyond Transcendence",//超凡之上
                "row": 9,
                "quote": "A silent tide has swept through our people. Its origin is untraceable, but they—no, we—have come to hold a certain conviction that our kind is destined for something far greater. We should investigate what has caused this mass hysteria—the whispers that promise we shall rule the stars.",
                "cost": 750,
                "uniques": [
                    "Triggers a [Grand Vision] event",
                    "Only available <when above [999] [Menace]> <when above [0] [Ascension Progress]>",
                ]
            },
            {
                "name": "Dark Tide Surging",//暗潮涌动
                "row": 10,
                "quote": "The prevailing theory is that our universe and the Shroud are interconnected—that large-scale disturbances or actions in one plane create ripple effects in the other. We should put this theory to the test.",
                "cost": 1250,
                "uniques": [
                    "Triggers a [Fount of Energy] event",
                    "Only available <when above [1999] [Menace]> <when above [1] [Ascension Progress]>",
                ]
            },
            {
                "name": "United as One",//万众一心
                "row": 11,
                "quote": "Our empire grows ever stronger—and with an undeniable sense of purpose uniting our entire species—our scientists are convinced that we are receiving infusion from the Shroud itself.",
                "cost": 1750,
                "uniques": [
                    "Triggers a [Otherworldly Infusion] event",
                    "Only available <when above [2999] [Menace]> <when above [2] [Ascension Progress]>",
                ]
            },
            {
                "name": "Tear the Veil",//撕碎帷幕
                "row": 12,
                "quote": "It is time to find a way to unleash the Shroud's energy into reality, and tame this source of power beyond ordinary understanding. According to current theory, a sufficiently large energy surge might tear down the barrier between the two planes, ultimately merging the two universes into one. The Shroud's majesty is vast—and the worthy shall claim it. Let us claim it.",
                "cost": 2250,
                "uniques": [
                    "Triggers a [The End Approaches] event",
                    "Triggers a [Star-Eater] event",
                    "Triggers a [Aetherophasic Engine] event",
                    "Only available <when above [4999] [Menace]> <when above [2] [Ascension Progress]>",
                ]
            },
